---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SuperSearch",
  description = "VS Code-style find for Chrome. Regex, whole word, match case, find in selection, cross-iframe search.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
